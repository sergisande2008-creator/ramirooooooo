{
  "entities": {
    "Order": {
      "title": "Order",
      "description": "Represents an order placed by a customer in the Nevada app",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "table": { "type": "string" },
        "tableNumber": { "type": "string" },
        "location": { "type": "string" },
        "guestCount": { "type": "number" },
        "status": { "type": "string" },
        "timestamp": { "type": "number" },
        "acceptedTimestamp": { "type": "number" },
        "completedTimestamp": { "type": "number" },
        "total": { "type": "number" },
        "paid": { "type": "boolean" },
        "allergies": { "type": "string" },
        "items": { "type": "array" }
      },
      "required": ["id", "table", "tableNumber", "location", "guestCount", "status", "timestamp", "total", "items"]
    },
    "BillRequest": {
      "title": "BillRequest",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "table": { "type": "string" },
        "tableNumber": { "type": "string" },
        "location": { "type": "string" },
        "timestamp": { "type": "number" },
        "status": { "type": "string" },
        "total": { "type": "number" },
        "paymentMethod": { "type": "string" },
        "splitWays": { "type": "number" },
        "itemsToPay": { "type": "array" }
      },
      "required": ["id", "table", "tableNumber", "location", "timestamp", "status", "total"]
    },
    "MenuConfig": {
       "title": "MenuConfig",
       "type": "object",
       "properties": {
         "items": { "type": "array" }
       },
       "required": ["items"]
    }
  },
  "firestore": {
    "/orders/{orderId}": {
      "schema": "#/entities/Order",
      "description": "Customer orders"
    },
    "/bills/{billId}": {
       "schema": "#/entities/BillRequest",
       "description": "Requests to pay the bill"
    },
    "/config/menu": {
       "schema": "#/entities/MenuConfig",
       "description": "Menu Configuration"
    }
  }
}
